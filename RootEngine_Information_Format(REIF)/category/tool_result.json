{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tool_result",
  "type": "object",
  "properties": {
    "tool_call_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{32}$",
      "description": "工具调用的id"
    },
    "result_content": {
      "type": "string",
      "description": "工具返回的内容"
    },
    "created_at": {
      "type": "string",
      "description": "创建时间",
      "format": "date-time"
    }
  },
  "required": ["tool_call_id","result_content","created_at"]
}