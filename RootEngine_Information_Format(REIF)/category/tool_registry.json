
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tool_registry",
  "description": "工具注册表",
  "type": "object",
  "description": "一条工具映射，tool_id为键，工具信息为值,//此表位于reif_content下",
  "patternProperties": {
    "^[0-9a-fA-F]{32}$": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "工具名称"
        },
        "function": {
          "description": "工具函数映射,传入运行时内存的函数对象"
        },
        "parameters": {
          "type": "object",
          "description": "工具所需的参数的定义"
        },
        "extra": {
          "type": "object",
          "additionalProperties": true,
          "description": "扩展元数据"
        }
      },
      "required": [
        "name",
        "function",
        "parameters"
      ]
    }
  }
}