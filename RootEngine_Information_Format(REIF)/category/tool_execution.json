
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tool_execution",
  "description":"用于储存工具调用的映射字典,//此表位于reif_content下",
  "type":"object",
  "patternProperties": {
    "^[0-9a-fA-F]{32}$": {
      "type": "object",
      "properties": {
        "tool_call": {"$ref": "tool_call.json",
          "description": "tool_call"
        },
        "tool_result": {
          "$ref": "tool_result.json",
          "description": "tool_result"
        }
      },
      "required": ["tool_call","tool_result"]
    }
  }
}