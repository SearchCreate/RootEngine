+        from rootengine_core.conversation.no_tool_conversation import NoToolConversation
+        entry = {
+            "reif_version": "1.0",
+            "reif_metadata": {
+                "id": "abc123",
+                "category": "conversation",
+                "created_at": "2024-01-01T00:00:00Z"
