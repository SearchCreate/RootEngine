+
+        with patch("rootengine_core.tool.tool.get_iso_timestamp", return_value="2024-01-01T00:00:00Z"):
+            result = tool_instance.execute_many(calls)
+
+        assert len(result) == 3
+        assert [r["call_id"] for r in result] == ids
