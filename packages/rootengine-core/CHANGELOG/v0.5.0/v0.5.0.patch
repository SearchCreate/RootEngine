+{
+  "$schema": "http://json-schema.org/draft-07/schema#",
+  "title": "llm_message",
+  "description": "LLM 对话消息单条格式，与 OpenAI 格式解耦",
+  "type": "object",
+  "properties": {
+    "role": {
+      "type": "string",
+      "enum": ["system", "user", "assistant", "tool"],
+      "description": "消息角色"
+    },
+    "content": {
+      "description": "消息内容",
